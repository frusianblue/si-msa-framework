// Jenkinsfile  (선언형 파이프라인 — 멀티서비스)
// 전제: 빌드 노드에 JDK 21, Docker 데몬, kubectl(내장 kustomize), (Sonar/Coverage/JUnit) 플러그인.
//       Testcontainers 통합테스트가 Docker 데몬을 사용하므로 빌드 노드에 Docker 필요.
// 구조: 게이트(아키텍처/테스트/품질)는 전 레포 1회 → 이미지 빌드는 서비스 매트릭스 → 배포는 kustomize 1회.
pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '20'))
    }

    environment {
        REGISTRY   = 'registry.example.com'
        VERSION    = '1.0.0'                 // 루트 build.gradle version 과 일치(bootJar 산출물 이름)
        IMAGE_TAG  = "${env.GIT_COMMIT ? env.GIT_COMMIT.take(12) : env.BUILD_NUMBER}"
        // 비밀이 아닌 접속 URL (DB 계정/비번은 credentials 로 주입). 서비스별 DB 분리: authdb / sidb.
        FLYWAY_URL_AUTH = 'jdbc:postgresql://prod-postgres.internal:5432/authdb'
        FLYWAY_URL_SI   = 'jdbc:postgresql://prod-postgres.internal:5432/sidb'
    }

    stages {
        // ===== 게이트(전 레포 1회) =====
        // 아키텍처 규칙(ArchUnit) — 가장 먼저, 실패 시 즉시 차단.
        stage('Architecture Rules') {
            steps {
                sh './gradlew :framework:framework-archtest:test --no-daemon'
            }
            post {
                always { junit allowEmptyResults: true, testResults: 'framework/framework-archtest/build/test-results/test/*.xml' }
            }
        }

        // 전 모듈 단위 + Testcontainers 통합테스트 + 멀티모듈 통합 JaCoCo 리포트
        stage('Build & Test') {
            steps {
                sh './gradlew test testCodeCoverageReport --no-daemon'
            }
            post {
                always {
                    junit '**/build/test-results/test/*.xml'
                    archiveArtifacts artifacts: 'build/reports/jacoco/testCodeCoverageReport/**', allowEmptyArchive: true
                }
            }
        }

        // 정적/포맷/취약점/Sonar — 병렬 게이트
        stage('Quality Gates') {
            parallel {
                stage('Spotless') {
                    steps { sh './gradlew spotlessCheck --no-daemon' }
                }
                stage('OWASP') {
                    steps { sh './gradlew dependencyCheckAggregate --no-daemon' }
                }
                stage('SonarQube') {
                    when { branch 'main' }
                    steps {
                        withSonarQubeEnv('sonar') {
                            sh './gradlew sonar --no-daemon'
                        }
                    }
                }
            }
        }

        // ===== 배포 게이트: 운영 DB 마이그레이션 정합성 검증(DB별) =====
        // flywayValidate: 적용된 마이그레이션 체크섬이 스크립트와 일치하는지 확인(드리프트/과거수정 검출).
        //   auth-server → authdb, user-service/admin-service → sidb. gateway 는 DB 없음.
        stage('Flyway Validate (deploy gate)') {
            when { branch 'main' }
            parallel {
                stage('authdb') {
                    steps {
                        withCredentials([usernamePassword(credentialsId: 'db-auth-prod',
                                usernameVariable: 'DB_USER', passwordVariable: 'DB_PASS')]) {
                            sh '''./gradlew :services:auth-server:flywayValidate --no-daemon \
                                  -Pflyway.url=${FLYWAY_URL_AUTH} \
                                  -Pflyway.user=${DB_USER} \
                                  -Pflyway.password=${DB_PASS}'''
                        }
                    }
                }
                stage('sidb') {
                    steps {
                        withCredentials([usernamePassword(credentialsId: 'db-si-prod',
                                usernameVariable: 'DB_USER', passwordVariable: 'DB_PASS')]) {
                            sh '''./gradlew :services:user-service:flywayValidate --no-daemon \
                                  -Pflyway.url=${FLYWAY_URL_SI} \
                                  -Pflyway.user=${DB_USER} \
                                  -Pflyway.password=${DB_PASS}'''
                        }
                    }
                }
            }
        }

        // ===== 이미지 빌드 & 푸시 (서비스 매트릭스, main 한정) =====
        // 4개 서비스를 병렬 셀로. 각 셀에서 bootJar → docker build(JAR_FILE 명시) → push.
        //   Dockerfile 은 JAR_FILE build-arg 를 받는다(plain jar 비활성 안 했으므로 boot jar 경로 명시).
        stage('Build & Push Images') {
            when { branch 'main' }
            matrix {
                axes {
                    axis {
                        name 'SERVICE'
                        values 'gateway', 'auth-server', 'user-service', 'admin-service'
                    }
                }
                stages {
                    stage('bootJar & docker') {
                        steps {
                            sh './gradlew :services:${SERVICE}:bootJar --no-daemon'
                            sh '''docker build -f deploy/docker/Dockerfile \
                                  --build-arg JAR_FILE=services/${SERVICE}/build/libs/${SERVICE}-${VERSION}.jar \
                                  -t ${REGISTRY}/si-msa/${SERVICE}:${IMAGE_TAG} \
                                  -t ${REGISTRY}/si-msa/${SERVICE}:latest .'''
                            withCredentials([usernamePassword(credentialsId: 'registry',
                                    usernameVariable: 'REG_USER', passwordVariable: 'REG_PASS')]) {
                                sh 'echo ${REG_PASS} | docker login ${REGISTRY} -u ${REG_USER} --password-stdin'
                                sh 'docker push ${REGISTRY}/si-msa/${SERVICE}:${IMAGE_TAG}'
                                sh 'docker push ${REGISTRY}/si-msa/${SERVICE}:latest'
                            }
                        }
                    }
                }
            }
        }

        // ===== K8s 롤아웃 (kustomize prod 오버레이, 매트릭스 밖 1회) =====
        //   ⚠️ Secret 은 매니페스트에 없다 — ESO/SealedSecrets 로 si-msa 네임스페이스에 사전 주입돼 있어야 한다.
        //   컨테이너 이름은 전 서비스 공통 'app' → set image 가 동일 키로 동작.
        stage('Deploy to K8s') {
            when { branch 'main' }
            steps {
                withCredentials([file(credentialsId: 'kubeconfig', variable: 'KUBECONFIG')]) {
                    sh '''kubectl apply -k deploy/k8s/overlays/prod
                          for svc in gateway auth-server user-service admin-service; do
                            kubectl -n si-msa set image deployment/$svc app=${REGISTRY}/si-msa/$svc:${IMAGE_TAG}
                            kubectl -n si-msa rollout status deployment/$svc --timeout=180s
                          done'''
                }
            }
        }
    }

    post {
        always { cleanWs() }
    }
}
